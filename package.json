{
  "name": "durgas-os",
  "version": "1.0.0",
  "description": "Windows 11 OS Replica built with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .next out",
    "clean:win": "clean.bat",
    "clean:ps": "powershell -ExecutionPolicy Bypass -File clean.ps1",
    "dev:clean": "npm run clean && npm run dev",
    "dev:enhanced": "npm run clean && cross-env NODE_ENV=development next dev",
    "dev:fast": "npm run clean && cross-env NODE_ENV=development next dev --config next.config.fast.js",
    "dev:test": "node dev-test.js",
    "dev:profile": "cross-env NODE_ENV=development next dev --profile",
    "perf:check": "node performance-check.js"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "zustand": "^4.4.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.292.0",
    "clsx": "^2.0.0",
    "class-variance-authority": "^0.7.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "@tailwindcss/typography": "^0.5.0",
    "@svgr/webpack": "^8.1.0",
    "stylelint": "^15.0.0",
    "stylelint-config-standard": "^34.0.0",
    "rimraf": "^5.0.0",
    "cross-env": "^7.0.0"
  }
}
